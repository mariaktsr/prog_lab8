<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootVBox" alignment="CENTER" prefHeight="320.0" prefWidth="350.0" spacing="15.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="client.gui.controller.AuthController" style="-fx-padding: 20;">
    <children>
        <!-- ✅ Локализованный заголовок -->
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="%window.auth.title" />

        <!-- ✅ Локализованные promptText -->
        <TextField fx:id="loginField" promptText="%auth.username" />
        <PasswordField fx:id="passwordField" promptText="%auth.password" />

        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <!-- ✅ Локализованные кнопки -->
                <Button fx:id="loginButton" onAction="#handleLogin" text="%auth.login" prefWidth="110.0" />
                <Button fx:id="registerButton" onAction="#handleRegister" text="%auth.register" prefWidth="110.0" />
            </children>
        </HBox>

        <!-- Статус (текст устанавливается программно в контроллере) -->
        <Label fx:id="statusLabel" text="" wrapText="true" alignment="CENTER" style="-fx-text-fill: #d32f2f;" />

        <HBox alignment="CENTER_RIGHT" prefWidth="200.0">
            <children>
                <Pane HBox.hgrow="ALWAYS" />
                <!-- ✅ Локализованная метка языка -->
                <Label text="%settings.language" />
                <ComboBox fx:id="languageSelector" prefWidth="130.0" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</VBox>
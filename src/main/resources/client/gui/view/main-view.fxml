<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.gui.controller.MainController">

    <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
    <top>
        <VBox spacing="5.0">

            <!-- Меню команд -->
            <MenuBar>
                <menus>
                    <Menu text="%main.menu.commands">
                        <items>
                            <!-- Команды без аргументов -->
                            <MenuItem text="%cmd.show" onAction="#handleShow" />
                            <MenuItem text="%cmd.info" onAction="#handleInfo" />
                            <MenuItem text="%cmd.clear" onAction="#handleClear" />
                            <MenuItem text="%cmd.sort" onAction="#handleSort" />
                            <MenuItem text="%cmd.sum" onAction="#handleSumOfImpactSpeed" />
                            <MenuItem text="%cmd.print.mood" onAction="#handlePrintFieldDescendingMood" />
                            <SeparatorMenuItem />

                            <!-- Команды с аргументами -->
                            <Menu text="%cmd.filter.name">
                                <items>
                                    <MenuItem text="%cmd.filter.name" onAction="#handleFilterContainsName" />
                                </items>
                            </Menu>

                            <Menu text="%cmd.remove.id">
                                <items>
                                    <MenuItem text="%cmd.remove.index" onAction="#handleRemoveAt" />
                                    <MenuItem text="%cmd.remove.id" onAction="#handleRemoveById" />
                                </items>
                            </Menu>

                            <Menu text="%dialog.add.title">
                                <items>
                                    <MenuItem text="%cmd.insert" onAction="#handleInsertAt" />
                                    <MenuItem text="%cmd.add" onAction="#handleAdd" />
                                </items>
                            </Menu>

                            <MenuItem text="%cmd.update" onAction="#handleUpdate" />
                            <MenuItem text="%cmd.execute" onAction="#handleExecuteScript" />
                        </items>
                    </Menu>

                    <Menu text="%main.menu.help">
                        <items>
                            <MenuItem text="%cmd.help" onAction="#handleHelp" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <!-- Панель поиска -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 5 10 5 10; -fx-background-color: #e8e8e8;">
                <children>
                    <!-- ✅ Локализованная метка поиска -->
                    <Label text="%table.filter" />
                    <!-- ✅ Локализованный placeholder -->
                    <TextField fx:id="searchField" HBox.hgrow="ALWAYS" promptText="%main.search.placeholder" />
                    <ComboBox fx:id="languageSelector" prefWidth="140.0" />
                </children>
            </HBox>

            <!-- Панель кнопок -->
            <ToolBar>
                <items>
                    <!-- ✅ Локализованная метка пользователя -->
                    <Label fx:id="userLabel" style="-fx-font-weight: bold;" text="%main.user.label" />
                    <Pane HBox.hgrow="ALWAYS" />

                    <!-- Основные кнопки -->
                    <Button fx:id="btnRefresh" onAction="#handleShow" text="%main.toolbar.refresh" />
                    <Button fx:id="btnAdd" onAction="#handleAdd" text="%main.toolbar.add" />
                    <Button fx:id="btnDelete" onAction="#handleRemove" text="%main.toolbar.delete" />
                    <Separator orientation="VERTICAL" />

                    <!-- Дополнительные команды -->
                    <Button fx:id="btnInfo" onAction="#handleInfo" text="%cmd.info" />
                    <Button fx:id="btnSort" onAction="#handleSort" text="%cmd.sort" />
                    <Button fx:id="btnSum" onAction="#handleSumOfImpactSpeed" text="%cmd.sum" />
                    <Button fx:id="btnClear" onAction="#handleClear" text="%cmd.clear" style="-fx-base: #ff9999;" />

                    <Separator orientation="VERTICAL" />
                    <Button fx:id="btnLogout" onAction="#handleLogout" text="%main.toolbar.logout" />
                </items>
            </ToolBar>
        </VBox>
    </top>

    <!-- ЦЕНТР: Таблица и Canvas -->
    <center>
        <SplitPane dividerPositions="0.55">
            <items>
                <TableView fx:id="table" editable="true">
                    <columns>
                        <!-- ✅ Локализованные заголовки колонок -->
                        <TableColumn fx:id="colId" prefWidth="60.0" text="%table.id" />
                        <TableColumn fx:id="colName" prefWidth="150.0" text="%table.name" />
                        <TableColumn fx:id="colCoordinates" prefWidth="120.0" text="%table.coordinates" />
                        <TableColumn fx:id="colCreationDate" prefWidth="140.0" text="%table.creationDate" />
                        <TableColumn fx:id="colRealHero" prefWidth="80.0" text="%table.realHero" />
                        <TableColumn fx:id="colWeapon" prefWidth="100.0" text="%table.weaponType" />
                        <TableColumn fx:id="colMood" prefWidth="100.0" text="%table.mood" />
                        <TableColumn fx:id="colOwner" prefWidth="120.0" text="%table.owner" />
                    </columns>
                </TableView>

                <AnchorPane fx:id="canvasContainer">
                    <children>
                        <Canvas fx:id="canvas" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </center>

    <!-- НИЖНЯЯ ПАНЕЛЬ: Статус -->
    <bottom>
        <HBox style="-fx-background-color: #f0f0f0; -fx-padding: 5 10 5 10;">
            <children>
                <!-- Статус (текст устанавливается программно) -->
                <Label fx:id="statusLabel" text="" />
                <Pane HBox.hgrow="ALWAYS" />
                <!-- ✅ Локализованный статус подключения -->
                <Label text="%auth.connected" style="-fx-text-fill: green;" />
            </children>
        </HBox>
    </bottom>
</BorderPane>